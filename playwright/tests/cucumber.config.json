{
    "default": {
      "paths": ["tests/features/**/*.feature"],
      "requireModule": ["ts-node/register"],
      "require": ["tests/steps/**/*.ts", "tests/support/**/*.ts"],
      "format": [
        "progress",
        "html:reports/cucumber.html",
        "json:reports/cucumber.json"
      ],
      "publishQuiet": true,
      "parallel": 1,
      "timeout": 30000
    }
  }
  